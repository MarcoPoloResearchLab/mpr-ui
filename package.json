{
  "name": "mpr-ui",
  "version": "3.9.0",
  "private": true,
  "description": "Reusable UI components for Marco Polo Research Lab projects, delivered as a single CDN-hosted script.",
  "license": "MIT",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test tests/*.test.js",
    "test:coverage": "npm run test:coverage:node && npm run test:coverage:browser",
    "test:coverage:node": "c8 --reporter=text --include=mpr-ui-config.js --check-coverage --lines 100 --functions 100 --branches 100 node --test tests/*.test.js",
    "test:coverage:browser": "node scripts/run-browser-coverage.js",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.0.3",
    "c8": "^11.0.0",
    "istanbul-lib-coverage": "^3.2.2",
    "js-yaml": "^4.1.0",
    "v8-to-istanbul": "^9.3.0"
  }
}
