# gHTTP configuration for mpr-ui demo
# Copy this file to demo/.env.ghttp before running docker compose.

# Internal container port (external port 4443 maps to this in docker-compose.yml)
GHTTP_SERVE_PORT=8443

# Serve the repository root so /demo/*, /docs/*, /mpr-ui.js, and /mpr-ui.css
# are reachable from the same origin.
GHTTP_SERVE_DIRECTORY=/app/www

# HTTPS with existing certificates (required for GIS to render)
# Mount your certificates in docker-compose.yml and reference the container paths here
GHTTP_SERVE_TLS_CERTIFICATE=/certs/cert.pem
GHTTP_SERVE_TLS_PRIVATE_KEY=/certs/key.pem

# Reverse proxy configuration for TAuth endpoints (same-origin operation)
# All auth demos use the same-origin proxy for /auth/*, /me, and /tauth.js.
# Format: /from=http://backend (request path is preserved, so /auth/nonce -> http://tauth:8080/auth/nonce)
GHTTP_SERVE_PROXIES=/auth=http://tauth:8080,/me=http://tauth:8080,/tauth.js=http://tauth:8080
